NODE_ENV=production
# Cloudflare Tunnel terminates TLS in Cloudflare and the cloudflared
# daemon connects out to Cloudflare, then forwards traffic into the
# local Node process. So the public API URL is https://api.tuneslam.com
# but the listener only needs to accept connections from the same host.
# Binding to 127.0.0.1 makes the API unreachable from the LAN / WAN
# directly — the only path in is through the tunnel.
PORT=4000
HOST=127.0.0.1

# Secret values (MONGO_URI, JWT_SECRET, TOKEN_ENC_KEY, SPOTIFY_CLIENT_ID/
# SECRET, FACEBOOK_APP_ID/SECRET) live in a local-only `backend/.env`
# which is gitignored. env.ts loads `.env` AFTER this file with
# `override: true`, so anything you put there wins. We deliberately do
# NOT list those vars here as `KEY=` placeholders — empty strings are
# treated as "set" by env.ts's required() check and would shadow the
# real values in `.env`.

PUBLIC_API_BASE_URL=https://api.tuneslam.com

ADMIN_URL=https://admin.tuneslam.com
USER_URL=https://tuneslam.com
PLAYER_URL=https://player.tuneslam.com
CORS_ORIGINS=https://admin.tuneslam.com,https://tuneslam.com,https://player.tuneslam.com

JWT_EXPIRES_IN=7d

SPOTIFY_REDIRECT_URI=https://api.tuneslam.com/api/auth/spotify/callback
FACEBOOK_REDIRECT_URI=https://api.tuneslam.com/api/auth/facebook/callback

LOG_LEVEL=info

