NODE_ENV=production
PORT=8080
HOST=0.0.0.0

# Beanstalk env vars override these in deploy:
MONGO_URI=

PUBLIC_API_BASE_URL=https://api.tuneslam.com

ADMIN_URL=https://admin.tuneslam.com
USER_URL=https://tuneslam.com
PLAYER_URL=https://player.tuneslam.com
CORS_ORIGINS=https://admin.tuneslam.com,https://tuneslam.com,https://player.tuneslam.com

JWT_SECRET=
JWT_EXPIRES_IN=7d
TOKEN_ENC_KEY=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://api.tuneslam.com/api/auth/spotify/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
