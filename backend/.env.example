# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/tuneslam

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secret (Generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URLs (for CORS)
ADMIN_URL=http://localhost:5173
USER_URL=http://localhost:5174
VIEWER_URL=http://localhost:5175
PLAYER_URL=http://localhost:5176


# Spotify API Credentials
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# Admin session Spotify callback (for playback control)
SPOTIFY_REDIRECT_ADMIN_URI=http://localhost:5000/api/spotify/callback
# User login/library Spotify callback (for OAuth login + library access)
SPOTIFY_REDIRECT_USER_URI=http://localhost:5000/api/auth/spotify/callback

# Facebook OAuth (for user login)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/facebook/callback

# Twilio API Credentials
TWILIO_ACCOUNT_SID=twilio-account-id
TWILIO_AUTH_TOKEN=twilio-auth-token

# Session Configuration
SESSION_COOKIE_SECRET=your-session-cookie-secret
