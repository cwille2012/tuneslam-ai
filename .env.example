# =============================================================================
# TuneSlam – top-level reference of all environment variables
# Copy the appropriate one of:
#   backend/.env.development   (loaded automatically when NODE_ENV=development)
#   backend/.env.production    (loaded automatically when NODE_ENV=production)
# Each frontend has its own .env.development / .env.production with VITE_ vars.
# =============================================================================

# ---- Backend ----------------------------------------------------------------

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Mongo (local instance assumed already running)
MONGO_URI=mongodb://127.0.0.1:27017/tuneslam

# Redis is currently unused – uncomment if you wire in a Socket.io adapter
# REDIS_URL=redis://127.0.0.1:6379

# Public URL that this backend is reachable at (used in OAuth redirect builders)
PUBLIC_API_BASE_URL=http://192.168.0.4:4000

# Frontends – used for CORS allowlist + post-OAuth redirects
ADMIN_URL=http://192.168.0.4:5173
USER_URL=http://192.168.0.4:5174
PLAYER_URL=http://192.168.0.4:5175
CORS_ORIGINS=http://192.168.0.4:5173,http://192.168.0.4:5174,http://192.168.0.4:5175,http://localhost:5173,http://localhost:5174,http://localhost:5175

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# AES-256 key (32 bytes hex = 64 chars) for encrypting Spotify refresh tokens
TOKEN_ENC_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Spotify (https://developer.spotify.com/dashboard) – required
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# When developing behind ngrok, set this to your ngrok https URL plus the path:
#   https://<your>.ngrok-free.app/api/auth/spotify/callback
SPOTIFY_REDIRECT_URI=http://192.168.0.4:4000/api/auth/spotify/callback

# Facebook (https://developers.facebook.com/apps) – required for FB login
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://192.168.0.4:4000/api/auth/facebook/callback

# Misc
LOG_LEVEL=info

# ---- Frontends (Vite) – every frontend has its own .env -----------------------
#
# frontends/admin/.env.development:
# VITE_API_BASE_URL=http://192.168.0.4:4000
# VITE_USER_URL=http://192.168.0.4:5174
# VITE_PLAYER_URL=http://192.168.0.4:5175
#
# frontends/user/.env.development:
# VITE_API_BASE_URL=http://192.168.0.4:4000
#
# frontends/player/.env.development:
# VITE_API_BASE_URL=http://192.168.0.4:4000
# VITE_USER_URL=http://192.168.0.4:5174
