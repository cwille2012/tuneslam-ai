option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    PORT: "8080"
    HOST: "0.0.0.0"
    # The following must be set on the environment via the EB console / CLI:
    #   MONGO_URI
    #   PUBLIC_API_BASE_URL
    #   ADMIN_URL, USER_URL, PLAYER_URL
    #   CORS_ORIGINS
    #   JWT_SECRET
    #   TOKEN_ENC_KEY  (64-character hex)
    #   SPOTIFY_CLIENT_ID, SPOTIFY_CLIENT_SECRET, SPOTIFY_REDIRECT_URI
    #   FACEBOOK_APP_ID, FACEBOOK_APP_SECRET, FACEBOOK_REDIRECT_URI
