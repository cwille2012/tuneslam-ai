# TuneSlam Admin Dashboard Environment Variables

# API Backend URL
# For local development: http://localhost:5000
# For network access: http://YOUR_SERVER_IP:5000
# For production: https://api.tuneslam.com
VITE_API_URL=http://localhost:5000

# Player URL
# For local development: http://localhost:5176
# For network access: http://YOUR_SERVER_IP:5176
# For production: https://player.tuneslam.com
VITE_PLAYER_URL=http://localhost:5176

# Viewer URL
# For local development: http://localhost:5175
# For network access: http://YOUR_SERVER_IP:5175
# For production: https://viewer.tuneslam.com
VITE_VIEWER_URL=http://localhost:5175
